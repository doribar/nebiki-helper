OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# スマホや別端末からTailscale/LAN経由でつなぐ前提なら 0.0.0.0 にします。
# 本体側の写真判定サーバーURLは http://PCのTailscale IP:3000 などにします。
HOST=0.0.0.0
PORT=3000
MAX_PHOTOS=6
MAX_PHOTO_MB=25
AI_TIMEOUT_MS=180000
OPENAI_REQUEST_TIMEOUT_MS=180000

# AIに渡す過去適切例1セットあたりの最大写真枚数です。
# 弁当・麺類の4枚セットを切らないよう、既定値は6です。
MAX_EXAMPLE_PHOTOS_PER_GROUP=6

# 必要なら許可するOriginを固定できます。通常は空欄または * でOKです。
CORS_ORIGIN=*
