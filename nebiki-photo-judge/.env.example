OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Tailscale Serve を使う場合は 127.0.0.1 のままでOKです。
# LAN内の別端末から http://PCのIP:3000 で直接つなぐ場合だけ 0.0.0.0 に変更します。
HOST=127.0.0.1
PORT=3000
MAX_PHOTOS=6
MAX_PHOTO_MB=25
AI_TIMEOUT_MS=45000

# AIに渡す過去適切例1セットあたりの最大写真枚数です。
# 弁当・麺類の4枚セットを切らないよう、既定値は6です。
MAX_EXAMPLE_PHOTOS_PER_GROUP=6

# 必要なら許可するOriginを固定できます。通常は空欄または * でOKです。
CORS_ORIGIN=*
